        <field name="Icon" type="StringTableFieldDefinition" value="PassiveFeature_ShieldMaster_Block" />
        <field name="Conditions" type="StringTableFieldDefinition" value="IsAbleToReact(context.Observer) and Self(context.Target,context.Observer) and IsAttack() and not IsSpell() and (HasStatus('RAISE_SHIELD',context.Observer) or HasStatus('RAISE_SHIELD_SPIRIT',context.Observer) or HasStatus('ParagonShield',context.Observer));" />
        <field name="Properties" type="StringTableFieldDefinition" value="IF(HasPassive('ShieldHardnessJunk',context.Observer)):AdjustRoll(-3);IF(HasPassive('ShieldHardnessCommon',context.Observer)):AdjustRoll(-5);IF(HasPassive('ShieldHardnessUncommon',context.Observer)):AdjustRoll(-8);IF(HasPassive('ShieldHardnessRare',context.Observer)):AdjustRoll(-10);IF(HasPassive('ShieldHardnessVeryRare',context.Observer)):AdjustRoll(-13);IF(HasPassive('ShieldHardnessLegendary',context.Observer)):AdjustRoll(-15);IF(HasPassive('BlessedShield',context.Observer)):AdjustRoll(-3);IF(HasStatus('EmblazonShieldStatus',context.Observer)):AdjustRoll(-1);IF(HasPassive('CorruptedShield',context.Observer)):DealDamage(OBSERVER_SOURCE,LevelMapValue(SongbirdsDamage),Necrotic,Magical);IF(HasPassive('CorruptedShield',context.Observer)):ApplyStatus(OBSERVER_SOURCE,DIVINESTRIKE_MELEE_VFX,100,1);IF(HasStatus('MAG_FLAMING_FIST_BLAZING_RETALIATION',context.Observer) and (IsMeleeWeaponAttack() or IsMeleeUnarmedAttack())):DealDamage(OBSERVER_SOURCE,4d6,Fire,Magical);IF(HasStatus('MAG_FLAMING_FIST_BLAZING_RETALIATION',context.Observer) and (IsMeleeWeaponAttack() or IsMeleeUnarmedAttack())):RemoveStatus(OBSERVER_OBSERVER,MAG_FLAMING_FIST_BLAZING_RETALIATION);" />
      </fields>
    </stat_object>
