        <field name="Icon" type="StringTableFieldDefinition" value="PassiveFeature_Portent_6" />
        <field name="Conditions" type="StringTableFieldDefinition" value="(HasStatus('GRABBED', context.Source) and HasSpellFlag(SpellFlags.Somatic) and FlatCheckFailed(5, context.Source)) or (HasStatus('SYNESTHESIA', context.Source) and HasStringInSpellConditions('ConcentrateSpell') and FlatCheckFailed(5, context.Source)) or ((Self(context.Source, context.Observer) and IsSpell() and not HasStringInSpellRoll('WeaponAttack')) and ((FlatCheckFailed(6, context.Source) and HasStatus('STUPEFIED_1', context.Source)) or (FlatCheckFailed(7, context.Source) and HasStatus('STUPEFIED_2', context.Source)) or (FlatCheckFailed(8, context.Source) and HasStatus('STUPEFIED_3', context.Source)) or (FlatCheckFailed(9, context.Source) and HasStatus('STUPEFIED_4', context.Source))));" />
        <field name="Properties" type="StringTableFieldDefinition" value="Counterspell();ApplyStatus(OBSERVER_SOURCE,FLAT_CHECK_OVERHEAD,100,0);" />
