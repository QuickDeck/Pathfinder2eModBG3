    <stat_object is_substat="false">
      <fields>
        <field name="UUID" type="IdTableFieldDefinition" value="5a8353bd-aa42-4191-b85e-2c48b17eba30" />
        <field name="Name" type="NameTableFieldDefinition" value="Interrupt_AttackOfOpportunity_OnCast" />
        <field name="DisplayName" type="TranslatedStringTableFieldDefinition" handle="hcf244533g8a50g71dbge8aag2b24f55e0534" version="3" />
        <field name="Description" type="TranslatedStringTableFieldDefinition" handle="h7b342ca0gea2dgca07gb43fg7ad99f8143ba" version="3" />
        <field name="Icon" type="StringTableFieldDefinition" value="PassiveFeature_AttackOfOpportunity" />
        <field name="Conditions" type="StringTableFieldDefinition" value="IsAbleToReact(context.Observer) and not Self(context.Source, context.Observer) and Enemy(context.Source, context.Observer) and not Uninterruptible() and not DistanceToEntityGreaterThan(2.5, context.ObserverPosition, context.Source) and not AnyEntityIsItem() and ((IsSpell() and HasSpellFlag(SpellFlags.Somatic)) or IsRangedAttack());" />
        <field name="InterruptDefaultValue" type="EnumerationListTableFieldDefinition" value="Ask;Enabled" enumeration_type_name="InterruptDefaultValue" version="1" />
        <field name="InterruptContext" type="EnumerationListTableFieldDefinition" value="OnSpellCast;OnPostRoll" enumeration_type_name="InterruptContext" version="1" />
        <field name="InterruptContextScope" type="EnumerationListTableFieldDefinition" value="Nearby" enumeration_type_name="InterruptContextScope" version="1" />
        <field name="Container" type="StringTableFieldDefinition" value="YesNoDecision" />
        <field name="Cost" type="StringTableFieldDefinition" value="ReactionActionPoint:1" />
        <field name="EnableCondition" type="StringTableFieldDefinition" value="not HasStatus('SG_Blinded')" />
        <field name="EnableContext" type="EnumerationListTableFieldDefinition" value="OnStatusApplied;OnStatusRemoved" enumeration_type_name="StatsFunctorContext" version="1" />
        <field name="Roll" type="StringTableFieldDefinition" value="Attack(AttackType.MeleeWeaponAttack)" />
        <field name="Success" type="StringTableFieldDefinition" value="IF(IsCritical()):Counterspell();ApplyStatus(OBSERVER_OBSERVER,INTERRUPT_RIPOSTE,100,0);UseSpell(OBSERVER_SOURCE,Target_AttackOfOpportunity_Crit,true,true,true);" />
        <field name="Failure" type="StringTableFieldDefinition" value="UseAttack(OBSERVER_SOURCE);" />
      </fields>
    </stat_object>
    <stat_object is_substat="false">
      <fields>
        <field name="UUID" type="IdTableFieldDefinition" value="7a7a7b47-dac0-42a3-b2e9-a96a2dd26248" />
        <field name="Name" type="NameTableFieldDefinition" value="FlatCheckReaction" />
        <field name="DisplayName" type="TranslatedStringTableFieldDefinition" handle="h09fe9c5dg708cg9f1cgd621gbc0937e031bf" version="2" />
        <field name="Description" type="TranslatedStringTableFieldDefinition" handle="h89beb024g9d49g119ag5062gaf2a6ebade13" version="3" />
        <field name="InterruptContextScope" type="EnumerationListTableFieldDefinition" value="Far" enumeration_type_name="InterruptContextScope" version="1" />
        <field name="Conditions" type="StringTableFieldDefinition" value="(FlatCheckFailed(5, context.Source) and not SpellIgnoresConcealed() and Self(context.Target,context.Observer) and not Self(context.Observer, context.Source) and IsConcealedTo(context.Target, context.Source, false) and not (HasStringInSpellConditions('AuditorySpell') or HasStringInSpellConditions('OlfactorySpell') or HasStringInSpellConditions('VisualSpell')) and not HasAoEConditions() and Enemy(context.Observer, context.Source) and (SpellTypeIs(SpellType.Target) or SpellTypeIs(SpellType.Throw) or SpellTypeIs(SpellType.Projectile)));" />
        <field name="Icon" type="StringTableFieldDefinition" value="PassiveFeature_Portent_5" />
